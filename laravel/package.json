{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "build:ssr": "vite build && vite build --ssr",
        "dev": "vite",
        "format": "prettier --write resources/",
        "format:check": "prettier --check resources/",
        "lint": "eslint . --fix",
        "lint:check": "php artisan wayfinder:generate --with-form && eslint .",
        "types:check": "php artisan wayfinder:generate --with-form && svelte-check --tsconfig ./tsconfig.json"
    },
    "devDependencies": {
        "@eslint/js": "^9.19.0",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@laravel/vite-plugin-wayfinder": "^0.1.3",
        "@tailwindcss/vite": "^4.3.1",
        "@types/node": "^22.20.0",
        "concurrently": "^9.2.3",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-import-resolver-typescript": "^4.4.5",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-svelte": "^3.19.0",
        "prettier": "^3.8.4",
        "prettier-plugin-svelte": "^3.5.2",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "svelte-check": "^4.6.0",
        "typescript": "^5.7.2",
        "typescript-eslint": "^8.61.1",
        "vite": "^8.0.16"
    },
    "dependencies": {
        "@inertiajs/svelte": "^3.4.0",
        "@inertiajs/vite": "^3.4.0",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "bits-ui": "^2.15.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "laravel-vite-plugin": "^3.1",
        "lucide-svelte": "^0.468.0",
        "svelte": "^5.56.3",
        "svelte-sonner": "^0.3.28",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.1",
        "tw-animate-css": "^1.2.5"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "4.62.2",
        "@rollup/rollup-win32-x64-msvc": "4.62.2",
        "@tailwindcss/oxide-linux-x64-gnu": "^4.0.1",
        "@tailwindcss/oxide-win32-x64-msvc": "^4.0.1",
        "lightningcss-linux-x64-gnu": "^1.29.1",
        "lightningcss-win32-x64-msvc": "^1.29.1"
    }
}
