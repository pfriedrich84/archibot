APP_NAME=ArchiBot
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Required immutable bootstrap origin: scheme + host + optional port only.
PAPERLESS_URL=http://paperless:8000
PAPERLESS_HTTP_TIMEOUT_SECONDS=10
PAPERLESS_HTTP_MAX_RESPONSE_BYTES=2097152
PAPERLESS_HTTP_MAX_PREVIEW_BYTES=52428800
SETUP_RATE_LIMIT_PER_MINUTE=5
MODEL_DISCOVERY_RATE_LIMIT_PER_MINUTE=10

# REQUIRED unless setup stores webhook.secret. Generate a unique value with: openssl rand -hex 32
# Deliberately empty: setup must collect a secret when deployment configuration does not provide one.
PAPERLESS_WEBHOOK_SECRET=
PAPERLESS_WEBHOOK_MAX_BYTES=262144
PAPERLESS_WEBHOOK_RATE_LIMIT_PER_MINUTE=60
# Isolated local/development opt-in only; production and testing always ignore this bypass.
PAPERLESS_WEBHOOK_DEVELOPMENT_BYPASS=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=archibot
DB_USERNAME=archibot
DB_PASSWORD=archibot
DATABASE_URL=postgresql+psycopg://archibot:archibot@postgres:5432/archibot

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
QUEUE_WORKER_TIMEOUT=21600
DB_QUEUE_RETRY_AFTER=21720
ARCHIBOT_STALE_CANCELLING_MINUTES=30

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
