# =============================================================================
# ArchiBot — Environment Configuration
# =============================================================================
# Copy to .env and fill in the required values.

# --- Docker Image -------------------------------------------------------------
# Image tag to use (e.g. latest, v1.2.0, sha-abc1234)
# IMAGE_TAG=latest

# --- Paperless-NGX (required) ------------------------------------------------
PAPERLESS_URL=http://paperless:8000
# Paperless authentication is handled through the Laravel setup/login flow.
# Do not configure a global PAPERLESS_TOKEN in .env.
PAPERLESS_INBOX_TAG_ID=1
# Optional: Tag ID to add after commit (e.g. "Verarbeitet")
# PAPERLESS_PROCESSED_TAG_ID=
# Keep the inbox tag (Posteingang) on documents after commit (default: true)
KEEP_INBOX_TAG=true

# --- AI Provider / Ollama-compatible / OpenAI-compatible -----------------------
# Default provider. Use "ollama" for Ollama-compatible endpoints or
# "openai_compatible" for OpenAI-compatible /v1 endpoints.
LLM_PROVIDER=ollama
# Base URL for the default provider. For openai_compatible include /v1,
# e.g. http://localhost:11434/v1.
# OPENAI_BASE_URL is accepted as an alias; OLLAMA_URL remains the legacy name.
OLLAMA_URL=http://ollama:11434
# OPENAI_BASE_URL=http://localhost:11434/v1
# Optional bearer token for the default OpenAI-compatible provider.
OPENAI_API_KEY=
# Optional additional named providers as compact JSON. Prefer api_key_env for
# secrets. Example for separate local OpenAI-compatible and Ollama-compatible profiles:
# AI_PROVIDER_PROFILES=[{"id":"local-openai","type":"openai_compatible","base_url":"http://localhost:11434/v1","api_key_env":"OPENAI_API_KEY"},{"id":"local-ollama","type":"ollama","base_url":"http://ollama:11434"}]
AI_PROVIDER_PROFILES=
# Optional per-role provider profile IDs. Empty means use the default provider.
CLASSIFICATION_PROVIDER=
EMBEDDING_PROVIDER=
OCR_PROVIDER=
JUDGE_PROVIDER=
CHAT_PROVIDER=
# Preferred role-based model names. Legacy OLLAMA_* aliases below remain supported.
# Classification/chat model (recommended on 6GB: gemma4:e4b; alternatives: qwen3:4b)
CLASSIFICATION_MODEL=gemma4:e4b
# Embedding model or provider alias. Qwen3 Embedding 4B resolves to 2560 dimensions in auto mode.
EMBEDDING_MODEL=qwen3-embedding:4b
# Embedding vector dimension for pgvector. 0 = auto-detect known defaults
# (qwen3-embedding:0.6b -> 1024, qwen3-embedding:4b -> 2560)
EMBEDDING_DIMENSION=0
# Text-only OCR correction model (OCR_MODE=text). OCR_MODEL is accepted as an alias.
OCR_TEXT_MODEL=qwen3:4b
# Judge model. Empty or same as CLASSIFICATION_MODEL avoids an extra native-Ollama GPU swap.
JUDGE_MODEL=qwen3:4b
# Legacy aliases for older scripts/images.
OLLAMA_MODEL=gemma4:e4b
OLLAMA_EMBED_MODEL=qwen3-embedding:4b
OLLAMA_EMBED_DIM=0
OLLAMA_OCR_MODEL=qwen3:4b
OLLAMA_JUDGE_MODEL=qwen3:4b
OLLAMA_TIMEOUT_SECONDS=600
# Retry settings for embedding requests (context-length truncation + transient 500s)
OLLAMA_EMBED_RETRIES=3
OLLAMA_EMBED_RETRY_BASE_DELAY=1.0
# Retry settings for chat/classification/OCR requests (transient 429/5xx/timeouts)
OLLAMA_CHAT_RETRIES=2
OLLAMA_CHAT_RETRY_BASE_DELAY=1.0
# Context windows (tokens). CLASSIFICATION_CONTEXT_WINDOW is also used by Chat/RAG and Judge.
# CHAT_CONTEXT_WINDOW and JUDGE_CONTEXT_WINDOW are not separate runtime settings today.
CLASSIFICATION_CONTEXT_WINDOW=16384
EMBEDDING_CONTEXT_WINDOW=8192
OCR_CONTEXT_WINDOW=12288
# Legacy context aliases.
OLLAMA_NUM_CTX=16384
OLLAMA_EMBED_NUM_CTX=8192
OLLAMA_OCR_NUM_CTX=12288
# Seconds to wait after unloading a model before loading the next one.
# Helps Ollama-compatible runtimes detect correct free VRAM on GPUs with slow memory recovery.
# Set to 0 to disable. OLLAMA_MODEL_SWAP_DELAY_SECONDS is accepted as a legacy alias.
OLLAMA_MODEL_SWAP_DELAY=8

# --- Worker -------------------------------------------------------------------
# Event-driven target: polling remains automatic reconciliation/fallback every 600 seconds.
POLL_INTERVAL_SECONDS=600
CONTEXT_MAX_DOCS=5
# Maximum number of tags the classifier may propose per document
CLASSIFICATION_MAX_TAGS=4
MAX_DOC_CHARS=24000
# Max characters of document text used for embedding/similarity search (default: 6000).
# EMBEDDING_MAX_CHARS is accepted as an alias by Python and Docker Compose.
EMBED_MAX_CHARS=6000
# Per-document embedding timeout in seconds.
EMBEDDING_DOCUMENT_TIMEOUT_SECONDS=180
# 0 = always require manual review. Set to e.g. 85 to auto-commit high-confidence results.
AUTO_COMMIT_CONFIDENCE=0
# Optional LLM-as-judge second pass: verify classifications with another LLM call.
# 101 = judge every result (confidence is 0-100). Lower values skip high-confidence results.
ENABLE_JUDGE_VERIFICATION=false
JUDGE_CONFIDENCE_THRESHOLD=101
# Recommended with gemma4:e4b classifier: qwen3:4b. Leave empty to reuse CLASSIFICATION_MODEL (no extra GPU model swap).
# JUDGE_MODEL above is the preferred name; OLLAMA_JUDGE_MODEL remains supported.
# OCR correction mode: off, text, vision_light, vision_full
# 6GB preset uses vision_light for stronger OCR validation.
OCR_MODE=vision_light
# Optional: only run/rerun OCR on documents carrying this Paperless tag ID. 0/empty = all documents.
OCR_REQUESTED_TAG_ID=0
OCR_VISION_MODEL=qwen3-vl:4b
# OCR_MODEL is accepted as a generic alias for OCR_TEXT_MODEL; OCR_VISION_MODEL remains the vision model.
# OCR_MODEL=qwen3:4b
OCR_VISION_MAX_PAGES=2
OCR_VISION_DPI=130

# --- Laravel/Svelte GUI -------------------------------------------------------
GUI_PORT=8088
# User-facing date format and timezone. Keep these in .env so Docker installs are explicit.
GUI_DATE_FORMAT=%d.%m.%Y
APP_TIMEZONE=Europe/Vienna
# Optional external app URL (e.g. https://archibot.example). Leave empty for local/self-hosted use.
APP_URL=
# Optional path prefix. Leave empty to serve the new Laravel/Svelte GUI at /.
APP_PATH_PREFIX=
# Optional: set a stable Laravel key yourself; otherwise the container stores one in /data/laravel/app_key.
APP_KEY=
APP_ENV=production
APP_DEBUG=false
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=archibot
DB_USERNAME=archibot
DB_PASSWORD=archibot
DATABASE_URL=postgresql+psycopg://archibot:archibot@postgres:5432/archibot
# Queue DB URL for Absurd. Keep this aligned with DATABASE_URL unless you explicitly split them.
ABSURD_DATABASE_URL=postgresql+psycopg://archibot:archibot@postgres:5432/archibot
ARCHIBOT_QUEUE_PREFIX=archibot
EVENT_RECOVERY_INTERVAL_SECONDS=30
ARCHIBOT_QUEUE_WORKER_CONCURRENCY=1
ARCHIBOT_QUEUE_WORKER_CLAIM_TIMEOUT=120
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database
# Python binary used by legacy maintenance commands while the event-driven migration proceeds.
ARCHIBOT_PYTHON_BINARY=python

# --- Webhook ------------------------------------------------------------------
# Shared secret for POST /api/webhooks/paperless. Leave empty for no auth in local dev.
# If set, callers must send: X-Webhook-Secret: <value>
PAPERLESS_WEBHOOK_SECRET=
# Optional direct enqueue for new persisted webhook deliveries. Leave false to rely on recovery.
# When enabled, Laravel uses ARCHIBOT_PYTHON_BINARY with the fixed safe command:
#   -m app.event_worker enqueue-webhook --delivery-id <id>
ARCHIBOT_WEBHOOK_DIRECT_ENQUEUE=false
# Deprecated legacy webhook secret for /webhook/new and /webhook/edit.
WEBHOOK_SECRET=

# --- MCP Server (optional) ---------------------------------------------------
# Set ENABLE_MCP=true to start the MCP SSE server alongside the main app
# (same container, no extra service needed).
ENABLE_MCP=false
# MCP_TRANSPORT=sse            # sse | streamable-http (stdio only for local CLI)
# MCP_PORT=3001
# MCP_HOST=0.0.0.0
# MCP_ENABLE_WRITE=false       # set to true to enable write tools
# MCP_API_KEY=                  # legacy static key; only used if Laravel MCP auth is disabled
# MCP_LARAVEL_AUTH_ENABLED=true  # validate MCP calls through Laravel-managed per-user tokens
# MCP_LARAVEL_PATH=/app/laravel
# MCP_LARAVEL_PHP_BINARY=php
# MCP_CLASSIFY_RATE_LIMIT=10   # max AI classifications per hour, 0=unlimited

# --- Storage / Logging --------------------------------------------------------
DATA_DIR=/data
LOG_LEVEL=INFO
